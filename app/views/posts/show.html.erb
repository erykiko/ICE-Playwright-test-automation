<% content_for :title, @post.title %>

<div class="bg-white shadow rounded-lg p-8">
  <%= render @post %>

  <div class="mt-8 flex space-x-4">
    <%= link_to "Edit this post", edit_post_path(@post), class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition" %>
    <%= link_to "Back to posts", posts_path, class: "bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-gray-700 transition" %>
    <%= button_to "Destroy this post", @post, method: :delete, class: "bg-red-600 text-white px-4 py-2 rounded-md hover:bg-red-700 transition" %>
  </div>
</div>
